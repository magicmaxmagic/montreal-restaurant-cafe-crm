# No API key is required.
# Business data is fetched server-side from OpenStreetMap through the public Overpass API.

# Optional persistent database.
# Works with Supabase, Neon, Vercel Postgres, or any PostgreSQL provider.
# If omitted, the app reads/writes data/businesses.json.
POSTGRES_URL=
# DATABASE_URL=

# Optional secret checked by /api/cron/enrich-emails.
# Vercel Cron can call the endpoint without it, but keep one for manual/remote protection.
CRON_SECRET=
